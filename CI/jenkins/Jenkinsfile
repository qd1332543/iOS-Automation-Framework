// Jenkins Pipeline 配置
// iOS Automation Framework - CI/CD 流水线

pipeline {
    agent any

    environment {
        PYTHON_VERSION = '3.11'
        TEST_ENV = 'staging'
        APPIUM_URL = 'http://127.0.0.1:4723'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    stages {

        // ========== 阶段1：环境准备 ==========
        stage('环境准备') {
            steps {
                echo '📋 检查运行环境...'
                sh '''
                    python3 --version || python --version
                    node --version || echo "Node.js 未安装"
                    appium --version 2>/dev/null || echo "Appium 未安装"
                    uname -a
                '''
            }
        }

        // ========== 阶段2：代码检出 ==========
        stage('代码检出') {
            steps {
                checkout scm
                sh '''
                    git log --oneline -5
                    git branch
                    git diff --name-only HEAD~1..HEAD 2>/dev/null || echo "首次提交"
                '''
            }
        }

        // ========== 阶段3：依赖安装 ==========
        stage('依赖安装') {
            steps {
                echo '📦 安装 Python 依赖...'
                sh '''
                    if [ ! -d "venv" ]; then
                        python3 -m venv venv
                    fi
                    source venv/bin/activate
                    pip install --upgrade pip setuptools wheel
                    pip install -r requirements.txt
                '''
            }
        }

        // ========== 阶段4：接口自动化测试 ==========
        stage('接口自动化测试') {
            steps {
                echo '🔌 运行接口自动化测试...'
                sh '''
                    source venv/bin/activate
                    mkdir -p Reports
                    pytest API_Automation/cases/ \
                        -v --tb=short --reruns 1 \
                        --alluredir=./Reports/api-results \
                        --junitxml=./Reports/junit-api.xml \
                        2>&1 | tee Reports/api-test-output.log
                '''
                junit 'Reports/junit-api.xml'
            }
            post {
                failure {
                    echo '⚠️ 接口测试存在失败，继续执行后续阶段'
                }
            }
        }

        // ========== 阶段5：UI 自动化测试 ==========
        stage('UI 自动化测试') {
            steps {
                echo '📱 运行 UI 自动化测试...'
                sh '''
                    source venv/bin/activate
                    mkdir -p Reports
                    if curl -s ${APPIUM_URL}/status > /dev/null; then
                        pytest UI_Automation/Tests/ \
                            -v --tb=long --reruns 1 \
                            --alluredir=./Reports/ui-results \
                            --junitxml=./Reports/junit-ui.xml \
                            2>&1 | tee Reports/ui-test-output.log
                    else
                        echo "⚠️ Appium Server 未启动，跳过 UI 测试"
                        echo '<?xml version="1.0"?><testsuite name="ui-tests" tests="0"></testsuite>' > Reports/junit-ui.xml
                    fi
                '''
                junit 'Reports/junit-ui.xml'
            }
        }

        // ========== 阶段6：报告生成 ==========
        stage('报告生成') {
            steps {
                echo '📊 生成 Allure 测试报告...'
                sh '''
                    mkdir -p Reports/allure-results-combined
                    [ -d "Reports/api-results" ] && cp -r Reports/api-results/* Reports/allure-results-combined/ 2>/dev/null || true
                    [ -d "Reports/ui-results" ] && cp -r Reports/ui-results/* Reports/allure-results-combined/ 2>/dev/null || true
                    allure generate Reports/allure-results-combined \
                        -o Reports/allure-report --clean 2>/dev/null || echo "Allure CLI 不可用"
                '''
            }
        }

        // ========== 阶段7：通知 ==========
        stage('通知') {
            steps {
                script {
                    echo "构建号: ${BUILD_NUMBER} | 状态: ${currentBuild.currentResult}"
                    // 可接入钉钉/企业微信 Webhook
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'Reports/**', allowEmptyArchive: true
                }
            }
        }

    } // end stages
} // end pipeline
